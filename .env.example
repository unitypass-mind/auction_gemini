# ================================
# 애플리케이션 설정
# ================================

# 환경 (development, staging, production)
ENVIRONMENT=development

# 디버그 모드 (프로덕션에서는 반드시 False)
DEBUG=False

# 애플리케이션 시크릿 키 (랜덤 문자열 생성 권장)
# 생성 방법: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here

# ================================
# 서버 설정
# ================================

# 서버 호스트 (기본: 0.0.0.0)
HOST=0.0.0.0

# 서버 포트 (기본: 8000)
PORT=8000

# 허용 도메인 (쉼표로 구분, * 는 모든 도메인 허용)
# 예: ALLOWED_HOSTS=example.com,www.example.com
ALLOWED_HOSTS=*

# CORS 허용 도메인 (쉼표로 구분)
# 예: CORS_ORIGINS=https://example.com,https://www.example.com
CORS_ORIGINS=*

# ================================
# 외부 API 키
# ================================

# 국토교통부 API 키 (선택)
ODCLOUD_API_KEY=your_api_key_here

# ================================
# 데이터베이스
# ================================

# SQLite (기본)
DATABASE_URL=sqlite:///./data/predictions.db

# PostgreSQL 예시 (프로덕션 권장)
# DATABASE_URL=postgresql://user:password@localhost:5432/auction_db

# MySQL 예시
# DATABASE_URL=mysql://user:password@localhost:3306/auction_db

# ================================
# 모델 설정
# ================================

# AI 모델 경로
MODEL_PATH=models/auction_model_v4.pkl

# 패턴 테이블 경로
PATTERN_PROPERTY_ROUND_PATH=models/pattern_property_round.pkl
PATTERN_REGION_PATH=models/pattern_region.pkl
PATTERN_COMPLEX_PATH=models/pattern_complex.pkl

# ================================
# 캐싱 (선택 - 성능 향상)
# ================================

# Redis URL (캐싱 활성화 시)
# REDIS_URL=redis://localhost:6379/0

# 캐시 만료 시간 (초)
CACHE_EXPIRE_SECONDS=3600

# ================================
# 보안 설정
# ================================

# Rate Limiting (분당 요청 제한)
RATE_LIMIT_PER_MINUTE=60

# 최대 업로드 파일 크기 (MB)
MAX_UPLOAD_SIZE_MB=10

# ================================
# 로깅
# ================================

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 로그 파일 경로
LOG_FILE=logs/app.log

# ================================
# 모니터링 (선택)
# ================================

# Sentry DSN (에러 추적)
# SENTRY_DSN=https://your_sentry_dsn_here

# Google Analytics Measurement ID
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
